<%- include('../partials/head', { title, isAdmin: false }) %>
<%- include('../partials/nav-public') %>

<main class="public-main">
  <section class="page-hero page-hero--with-image">
    <div class="page-hero-content">
      <h1>Shelf</h1>
      <p>Books, courses, articles, and movies — a curated collection of everything I'm learning from.</p>
    </div>
  </section>

  <div class="shelf-quick-links" style="max-width: var(--max-width, 1200px); margin: 0 auto; padding: 0 2rem 1.5rem; display: flex; flex-wrap: wrap; gap: 0.5rem;">
    <a href="/books/vocational" class="shelf-quick-link">Vocational Books &rarr;</a>
    <a href="/books/literary" class="shelf-quick-link">Literary Books &rarr;</a>
    <a href="/courses" class="shelf-quick-link">Courses &rarr;</a>
    <a href="/articles-read" class="shelf-quick-link">Articles Read &rarr;</a>
    <a href="/research-papers" class="shelf-quick-link">Research Papers &rarr;</a>
    <a href="/writing-ideas" class="shelf-quick-link">Writing Ideas &rarr;</a>
    <a href="/iconic-bitch" class="shelf-quick-link">Iconic Bitch &rarr;</a>
    <a href="/solo-date" class="shelf-quick-link">Solo Date &rarr;</a>
    <a href="/travel" class="shelf-quick-link">Travel &rarr;</a>
  </div>

  <% if (iconicBitch && iconicBitch.length) { %>
  <section class="shelf-section shelf-section--featured">
    <div class="shelf-section-header">
      <h2 class="shelf-section-title">Iconic Bitch</h2>
      <a href="/iconic-bitch" class="section-link">View all &rarr;</a>
    </div>
    <div class="shelf-items">
      <% iconicBitch.forEach(item => { %>
      <a href="<%= item.url || '/iconic-bitch' %>" class="shelf-card shelf-card--featured shelf-card--link" <%= item.url ? 'target="_blank" rel="noopener"' : '' %>>
        <img class="shelf-card-icon" src="https://www.google.com/s2/favicons?domain=<%= item.url ? new URL(item.url).hostname : 'google.com' %>&sz=32" alt="" width="20" height="20" loading="lazy">
        <div class="shelf-card-info">
          <h4><%= item.title %></h4>
          <p class="muted"><%= item.author %></p>
          <p class="shelf-card-excerpt"><%= item.excerpt %></p>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% if (books.length > 0) { %>
  <section class="shelf-section">
    <div class="shelf-section-header">
      <h2 class="shelf-section-title">Books</h2>
      <div class="shelf-section-links">
        <a href="/books/vocational" class="section-link">Vocational &rarr;</a>
        <a href="/books/literary" class="section-link">Literary &rarr;</a>
      </div>
    </div>
    <% const bookGroups = groupByMonth(books); %>
    <% Object.keys(bookGroups).forEach(month => { %>
    <div class="shelf-month">
      <h3 class="month-label"><%= month %></h3>
      <div class="shelf-items">
        <% bookGroups[month].forEach(book => { %>
        <div class="shelf-card">
          <%- include('../partials/media-cover', { url: book.coverUrl, size: 'thumb', className: 'shelf-cover media-cover', variant: 'book' }) %>
          <div class="shelf-card-info">
            <h4><%= book.title %></h4>
            <p class="muted"><%= book.author %></p>
            <span class="status-badge status-<%= book.status %>"><%= book.status %></span>
            <% if (book.rating) { %>
            <span class="rating">★ <%= book.rating %>/5</span>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </section>
  <% } %>

  <% if (courses.length > 0) { %>
  <section class="shelf-section">
    <div class="shelf-section-header">
      <h2 class="shelf-section-title">Courses</h2>
      <a href="/courses" class="section-link">View all &rarr;</a>
    </div>
    <div class="shelf-items">
      <% courses.forEach(course => { %>
      <a href="<%= course.url || '/courses' %>" class="shelf-card shelf-card--link" <%= course.url ? 'target="_blank" rel="noopener"' : '' %>>
        <img class="shelf-card-icon" src="https://www.google.com/s2/favicons?domain=<%= course.url ? new URL(course.url).hostname : 'coursera.org' %>&sz=32" alt="" width="20" height="20" loading="lazy">
        <div class="shelf-card-info">
          <h4><%= course.title %></h4>
          <p class="muted"><%= course.platform || '' %> <% if (course.instructor) { %>— <%= course.instructor %><% } %></p>
          <span class="status-badge status-<%= course.status %>"><%= course.status %></span>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% if (articles.length > 0) { %>
  <section class="shelf-section">
    <div class="shelf-section-header">
      <h2 class="shelf-section-title">Articles</h2>
      <a href="/articles-read" class="section-link">Full reading log &rarr;</a>
    </div>
    <div class="shelf-items shelf-items--articles">
      <% articles.slice(0, 8).forEach(article => { %>
      <a href="<%= article.url || '/articles-read' %>" class="shelf-card shelf-card--compact shelf-card--link" <%= article.url ? 'target="_blank" rel="noopener"' : '' %>>
        <img class="shelf-card-icon" src="https://www.google.com/s2/favicons?domain=<%= article.url ? new URL(article.url).hostname : 'medium.com' %>&sz=32" alt="" width="20" height="20" loading="lazy">
        <div class="shelf-card-info">
          <h4><%= article.title %></h4>
          <p class="muted"><%= article.source || '' %></p>
          <span class="status-badge status-<%= article.status %>"><%= article.status %></span>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% if (movies.length > 0) { %>
  <section class="shelf-section">
    <h2 class="shelf-section-title">Movies</h2>
    <div class="shelf-items">
      <% movies.forEach(movie => { %>
      <div class="shelf-card">
        <div class="shelf-card-info">
          <h4><%= movie.title %></h4>
          <p class="muted"><%= movie.director || '' %> <% if (movie.year) { %>(<%= movie.year %>)<% } %></p>
          <span class="status-badge status-<%= movie.status %>"><%= movie.status %></span>
          <% if (movie.rating) { %>
          <span class="rating">★ <%= movie.rating %>/5</span>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% if (books.length === 0 && courses.length === 0 && articles.length === 0 && movies.length === 0 && (!iconicBitch || !iconicBitch.length)) { %>
  <p style="text-align: center; padding: 4rem 2rem; color: var(--ink-muted, #9B9B9B);">Nothing on the shelf yet.</p>
  <% } %>
</main>

<%- include('../partials/footer') %>
