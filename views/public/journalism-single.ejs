<%- include('../partials/head', { title, isAdmin: false }) %>
<%- include('../partials/nav-public') %>

<main class="public-main">
  <article class="journalism-single">
    <% if (article.heroImageUrl) { %>
    <div class="journalism-hero" style="background-image: url('<%= img(article.heroImageUrl, 'hero') %>')">
      <div class="journalism-hero-overlay"></div>
      <div class="journalism-hero-content">
        <% if (article.issue) { %><span class="journalism-type-badge">Issue <%= article.issue %></span><% } %>
        <h1><%= article.title %></h1>
        <p class="journalism-hero-meta">By <%= article.author %> · <%= formatDate(article.datePublished) %></p>
      </div>
    </div>
    <% } else { %>
    <header class="journalism-header-plain">
      <h1><%= article.title %></h1>
      <p class="journalism-hero-meta">By <%= article.author %> · <%= formatDate(article.datePublished) %></p>
    </header>
    <% } %>

    <div class="journalism-container prose">
      <% article.body.split('\n\n').forEach(para => { %>
      <p><%= para %></p>
      <% }) %>

      <% if (article.tags && article.tags.length) { %>
      <div class="tags journalism-tags">
        <% article.tags.forEach(tag => { %>
        <span class="tag"><%= tag %></span>
        <% }) %>
      </div>
      <% } %>

      <footer class="writing-footer">
        <a href="/journalism" class="back-link">&larr; Back to Journalism</a>
        <% if (article.url) { %>
        <a href="<%= article.url %>" target="_blank" rel="noopener" class="external-link">Read on AUIS Voice &rarr;</a>
        <% } else { %>
        <a href="https://voice.auis.edu.krd/" target="_blank" rel="noopener" class="external-link">The AUIS Voice &rarr;</a>
        <% } %>
      </footer>

      <% if (related && related.length) { %>
      <section class="related-writings">
        <h3>More journalism</h3>
        <div class="related-grid">
          <% related.forEach(r => { %>
          <a href="/journalism/<%= r.slug %>" class="related-card">
            <% if (r.heroImageUrl) { %>
            <div class="related-card-image" style="background-image: url('<%= img(r.heroImageUrl, 'thumb') %>')"></div>
            <% } %>
            <div class="related-card-body">
              <h4><%= r.title %></h4>
              <p><%= formatDate(r.datePublished) %></p>
            </div>
          </a>
          <% }) %>
        </div>
      </section>
      <% } %>
    </div>
  </article>
</main>

<%- include('../partials/footer') %>
