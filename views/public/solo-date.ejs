<%- include('../partials/head', { title, isAdmin: false }) %>
<%- include('../partials/nav-public') %>

<main class="public-main">
  <section class="page-hero page-hero--mesh page-hero--compact page-hero--warm">
    <p class="hero-eyebrow">Self & Care</p>
    <h1>Solo Date</h1>
    <p>Adventures taken alone — museums, walks, coffee shops, and the quiet joy of keeping your own company.</p>
  </section>

  <% if (!dates.length) { %>
  <p class="empty-state">No solo dates logged yet.</p>
  <% } else { %>
  <div class="solo-timeline">
    <% dates.forEach(entry => { %>
    <article class="solo-card card-lift">
      <div class="solo-card-date">
        <time><%= formatDate(entry.date) %></time>
        <span class="solo-activity"><%= entry.activity %></span>
      </div>
      <div class="solo-card-body">
        <%- include('../partials/media-cover', { url: entry.heroImageUrl, size: 'card', className: 'solo-card-image media-cover', variant: 'travel' }) %>
        <h2><%= entry.title %></h2>
        <% if (entry.location) { %>
        <p class="solo-location"><%= entry.location %></p>
        <% } %>
        <% if (entry.mood) { %>
        <span class="solo-mood"><%= entry.mood %></span>
        <% } %>
        <p class="solo-notes"><%= entry.notes %></p>
        <% if (entry.tags && entry.tags.length) { %>
        <div class="tags">
          <% entry.tags.forEach(tag => { %>
          <span class="tag"><%= tag %></span>
          <% }) %>
        </div>
        <% } %>
      </div>
    </article>
    <% }) %>
  </div>
  <% } %>
</main>

<%- include('../partials/footer') %>
