<%- include('../partials/head', { title, isAdmin: false }) %>
<%- include('../partials/nav-public') %>

<main class="public-main">
  <section class="hero hero--image" <% if (heroImage) { %>style="background-image: url('<%= img(heroImage, 'hero') %>')"<% } %>>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Science Communicator & Creator</p>
      <h1 class="hero-title">Hello, I'm <span class="logo-accent">Z</span>sinTech</h1>
      <p class="hero-desc">Essays, projects, and thoughts on making science accessible and fascinating for everyone — including <a href="/popsci">PopSci AI</a>.</p>
      <div class="hero-actions">
        <a href="/writings" class="btn btn-primary">Read My Essays</a>
        <a href="/about" class="btn btn-ghost">About Me</a>
      </div>
    </div>
  </section>

  <% if (featured) { %>
  <section class="featured-hero">
    <a href="/writings/<%= featured.slug %>" class="featured-hero-link">
      <div class="featured-hero-image" style="background-image: url('<%= img(featured.heroImageUrl, 'card') %>')"></div>
      <div class="featured-hero-content">
        <span class="featured-hero-type"><%= featured.type %></span>
        <h2><%= featured.title %></h2>
        <p><%= featured.excerpt %></p>
        <span class="read-more">Read essay &rarr;</span>
      </div>
    </a>
  </section>
  <% } %>

  <section class="essays-grid-section">
    <div class="section-header">
      <h2>Essays & Writings</h2>
      <a href="/writings" class="section-link">View all &rarr;</a>
    </div>
    <div class="essays-grid">
      <% essays.forEach((essay, i) => { %>
      <article class="essay-card <%= i === 0 ? 'essay-card--wide' : '' %>">
        <a href="/writings/<%= essay.slug %>" class="essay-card-link">
          <% if (essay.heroImageUrl) { %>
          <div class="essay-card-image" style="background-image: url('<%= img(essay.heroImageUrl, 'card') %>')">
            <div class="essay-card-overlay"></div>
          </div>
          <% } %>
          <div class="essay-card-body">
            <div class="essay-card-meta">
              <span class="essay-card-type"><%= essay.type %></span>
              <time><%= formatDate(essay.dateWritten) %></time>
            </div>
            <h3><%= essay.title %></h3>
            <p><%= essay.excerpt %></p>
          </div>
        </a>
      </article>
      <% }) %>
    </div>
  </section>

  <% if (projects && projects.length) { %>
  <section class="projects-grid-section">
    <div class="section-header">
      <h2>Projects</h2>
      <a href="/writings?type=project" class="section-link">View all &rarr;</a>
    </div>
    <div class="projects-grid">
      <% projects.forEach(p => { %>
      <article class="project-card">
        <a href="/writings/<%= p.slug %>" class="project-card-link">
          <div class="project-card-image" style="background-image: url('<%= img(p.heroImageUrl, 'card') %>')">
            <div class="project-card-overlay"></div>
          </div>
          <div class="project-card-body">
            <span class="project-card-label">Project</span>
            <h3><%= p.title %></h3>
            <p><%= p.excerpt %></p>
          </div>
        </a>
      </article>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% if (journalism && journalism.length) { %>
  <section class="journalism-home-section">
    <div class="section-header">
      <h2>Journalism — <a href="https://voice.auis.edu.krd/" target="_blank" rel="noopener" class="section-link-inline">The AUIS Voice</a></h2>
      <a href="/journalism" class="section-link">All articles &rarr;</a>
    </div>
    <div class="journalism-home-grid">
      <% journalism.slice(0, 3).forEach(article => { %>
      <article class="journalism-home-card">
        <a href="/journalism/<%= article.slug %>">
          <% if (article.heroImageUrl) { %>
          <div class="journalism-home-image" style="background-image: url('<%= img(article.heroImageUrl, 'thumb') %>')"></div>
          <% } %>
          <div class="journalism-home-body">
            <time><%= formatDate(article.datePublished) %></time>
            <h3><%= article.title %></h3>
            <p><%= article.excerpt.substring(0, 100) %>...</p>
          </div>
        </a>
      </article>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% if (stories && stories.length) { %>
  <section class="story-spotlight">
    <% const story = stories[0]; %>
    <div class="section-header">
      <h2>Fiction</h2>
      <a href="/stories" class="section-link">All stories &rarr;</a>
    </div>
    <a href="/stories/<%= story.slug %>" class="story-spotlight-link">
      <div class="story-spotlight-inner" style="background-image: url('<%= img(story.heroImageUrl, 'hero') %>')">
        <div class="story-spotlight-overlay"></div>
        <div class="story-spotlight-content">
          <span class="story-spotlight-label">Story · AUIS Literary Journal</span>
          <h2><%= story.title %></h2>
          <p><%= story.excerpt %></p>
          <span class="read-more">Read story &rarr;</span>
        </div>
      </div>
    </a>
  </section>
  <% } %>

  <% if (popsciReels && popsciReels.length) { %>
  <section class="popsci-home-section">
    <div class="section-header">
      <h2>PopSci AI</h2>
      <a href="/popsci" class="section-link">All reels &rarr;</a>
    </div>
    <div class="popsci-home-scroll">
      <% popsciReels.slice(0, 4).forEach(reel => { %>
      <a href="/popsci/<%= reel.slug %>" class="popsci-home-card">
        <div class="popsci-home-thumb" style="background-image: url('<%= img(reel.heroImageUrl, 'thumb') %>')"></div>
        <span><%= reel.title %></span>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% if (latestReflection) { %>
  <section class="reflection-teaser">
    <div class="section-header">
      <h2>Latest Reflection</h2>
      <a href="/reflections" class="section-link">All reflections &rarr;</a>
    </div>
    <div class="reflection-teaser-body">
      <% if (latestReflection.title) { %><h3><%= latestReflection.title %></h3><% } %>
      <p><%= latestReflection.body.substring(0, 280) %>...</p>
      <a href="/reflections" class="read-more">Read reflection &rarr;</a>
    </div>
  </section>
  <% } %>

  <% if (courses && courses.length || articles && articles.length || vocationalBooks && vocationalBooks.length) { %>
  <section class="shelf-home-section">
    <div class="section-header">
      <h2>From the Shelf</h2>
      <a href="/shelf" class="section-link">Full shelf &rarr;</a>
    </div>

    <% if (courses && courses.length) { %>
    <div class="shelf-home-block">
      <h3 class="shelf-home-label"><a href="/courses">Courses</a></h3>
      <div class="shelf-home-items">
        <% courses.forEach(course => { %>
        <a href="/courses" class="shelf-home-chip">
          <strong><%= course.title %></strong>
          <span><%= course.status ? course.status.replace(/-/g, ' ') : 'queued' %></span>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% if (articles && articles.length) { %>
    <div class="shelf-home-block">
      <h3 class="shelf-home-label"><a href="/articles-read">Articles</a></h3>
      <div class="shelf-home-items">
        <% articles.forEach(article => { %>
        <a href="<%= article.url || '/articles-read' %>" class="shelf-home-chip" <%= article.url ? 'target="_blank" rel="noopener"' : '' %>>
          <strong><%= article.title %></strong>
          <span><%= article.source || 'reading log' %></span>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% if (vocationalBooks && vocationalBooks.length) { %>
    <div class="shelf-home-block">
      <h3 class="shelf-home-label"><a href="/books/vocational">Vocational Books</a> · <a href="/books/literary">Literary</a></h3>
      <div class="shelf-home-items shelf-home-items--books">
        <% vocationalBooks.forEach(book => { %>
        <a href="/books/vocational" class="shelf-home-book">
          <% if (book.coverUrl) { %>
          <div class="shelf-home-book-cover media-cover" style="background-image: url('<%= img(book.coverUrl, 'thumb') %>')"></div>
          <% } else { %>
          <div class="shelf-home-book-cover media-cover media-cover--placeholder"></div>
          <% } %>
          <div>
            <strong><%= book.title %></strong>
            <% if (book.category) { %><span class="shelf-home-book-cat"><%= book.category %></span><% } %>
          </div>
        </a>
        <% }) %>
        <% if (literaryBooks && literaryBooks.length) { literaryBooks.forEach(book => { %>
        <a href="/books/literary" class="shelf-home-book">
          <% if (book.coverUrl) { %>
          <div class="shelf-home-book-cover media-cover" style="background-image: url('<%= img(book.coverUrl, 'thumb') %>')"></div>
          <% } else { %>
          <div class="shelf-home-book-cover media-cover media-cover--placeholder"></div>
          <% } %>
          <div>
            <strong><%= book.title %></strong>
            <% if (book.category) { %><span class="shelf-home-book-cat"><%= book.category %></span><% } %>
          </div>
        </a>
        <% }) } %>
      </div>
    </div>
    <% } %>
  </section>
  <% } %>

  <section class="reading-spaces">
    <div class="section-header">
      <h2>Reading & Research</h2>
    </div>
    <div class="reading-spaces-grid">
      <div class="reading-space-card">
        <a href="/articles-read">
          <span class="reading-space-label">Reading Log</span>
          <h3>Articles Read</h3>
          <p>Journalism, essays, and long reads — with personal notes on each.</p>
        </a>
      </div>
      <div class="reading-space-card">
        <a href="/writing-ideas">
          <span class="reading-space-label">Idea Garden</span>
          <h3>Writing Ideas</h3>
          <p>Research clusters and essay seeds waiting to become full pieces.</p>
        </a>
      </div>
      <div class="reading-space-card">
        <a href="/iconic-bitch">
          <span class="reading-space-label">Curated Shelf</span>
          <h3>Iconic Bitch</h3>
          <p>Books that shaped how I think about science and absurdity.</p>
        </a>
      </div>
      <div class="reading-space-card">
        <a href="/research-papers">
          <span class="reading-space-label">Academic</span>
          <h3>Research Papers</h3>
          <p>Peer-reviewed studies and references behind my research.</p>
        </a>
      </div>
      <div class="reading-space-card">
        <a href="/solo-date">
          <span class="reading-space-label">Self & Care</span>
          <h3>Solo Date</h3>
          <p>Adventures taken alone — museums, walks, and quiet joy.</p>
        </a>
      </div>
      <div class="reading-space-card">
        <a href="/travel">
          <span class="reading-space-label">Plan All the Way</span>
          <h3>Travel</h3>
          <p>Itineraries, dream destinations, and trip notes from Notion.</p>
        </a>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
