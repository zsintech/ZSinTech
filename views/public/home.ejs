<%- include('../partials/head', { title, isAdmin: false }) %>
<%- include('../partials/nav-public') %>

<main class="public-main dashboard-main">

  <section class="dash-hero">
    <div class="dash-hero-copy">
      <p class="hero-eyebrow">Software Engineering · Business · Science Communication</p>
      <h1 class="hero-title">Research.<br>Storytelling.<br>Impact.</h1>
      <p class="hero-desc">Technology, healthcare, civic access, and environmental research — including <a href="/writings/stories-of-khasa">Stories of Khasa</a>, <a href="/journalism">The AUIS Voice</a>, and <a href="/popsci">PopSci AI</a>.</p>
      <div class="dash-hero-actions">
        <a href="/activities" class="btn btn-primary">Explore My Work</a>
        <a href="/about" class="btn btn-outline">About</a>
      </div>
    </div>
    <div class="dash-hero-media">
      <%- include('../partials/media-cover', { url: heroImage, size: 'hero', className: 'media-cover', variant: 'science' }) %>
    </div>
  </section>

  <% if (projects && projects.length) { %>
  <section class="dash-panel dash-row" style="margin-bottom: var(--gap-xl);">
    <div class="dash-panel-header">
      <h2 class="dash-panel-title">Featured Projects</h2>
      <a href="/projects" class="dash-panel-link">All projects &rarr;</a>
    </div>
    <div class="project-strip">
      <% projects.slice(0, 3).forEach(p => { %>
      <article class="project-tile">
        <a href="/writings/<%= p.slug %>" class="project-tile-link">
          <div class="project-tile-img">
            <%- include('../partials/media-cover', { url: p.heroImageUrl || p.coverUrl, size: 'card', className: 'media-cover', variant: 'science' }) %>
          </div>
          <div class="project-tile-body">
            <h3><%= p.title %></h3>
            <p><%= p.excerpt %></p>
          </div>
        </a>
      </article>
      <% }) %>
    </div>
  </section>
  <% } %>

  <div class="dash-row dash-row--2">
    <% if (activities && activities.length) { %>
    <section class="dash-panel">
      <div class="dash-panel-header">
        <h2 class="dash-panel-title">Recent Activity</h2>
        <a href="/activities" class="dash-panel-link">All &rarr;</a>
      </div>
      <div class="tile-grid">
        <% activities.slice(0, 5).forEach(activity => { %>
        <article class="tile">
          <a href="/activities/<%= activity.slug %>" class="tile-link">
            <div class="tile-thumb">
              <%- include('../partials/media-cover', { url: activity.heroImageUrl || activity.coverUrl, size: 'thumb', className: 'media-cover', variant: 'journal' }) %>
            </div>
            <div class="tile-body">
              <div class="tile-meta">
                <span class="tile-badge tile-badge--<%= activity.kind %>"><%= activity.kind %></span>
                <time><%= formatDate(activity.datePublished) %></time>
              </div>
              <h3 class="tile-title"><%= activity.title %></h3>
            </div>
          </a>
        </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <section class="dash-panel">
      <div class="dash-panel-header">
        <h2 class="dash-panel-title">Essays</h2>
        <a href="/writings" class="dash-panel-link">All &rarr;</a>
      </div>
      <div class="tile-grid">
        <% essays.slice(0, 5).forEach(essay => { %>
        <article class="tile">
          <a href="/writings/<%= essay.slug %>" class="tile-link">
            <div class="tile-thumb">
              <%- include('../partials/media-cover', { url: essay.heroImageUrl, size: 'thumb', className: 'media-cover', variant: 'science' }) %>
            </div>
            <div class="tile-body">
              <div class="tile-meta"><time><%= formatDate(essay.dateWritten) %></time></div>
              <h3 class="tile-title"><%= essay.title %></h3>
            </div>
          </a>
        </article>
        <% }) %>
      </div>
    </section>
  </div>

  <div class="dash-row dash-row--2">
    <% if (journalism && journalism.length) { %>
    <section class="dash-panel">
      <div class="dash-panel-header">
        <h2 class="dash-panel-title">Journalism</h2>
        <a href="/journalism" class="dash-panel-link">AUIS Voice &rarr;</a>
      </div>
      <div class="tile-grid">
        <% journalism.slice(0, 4).forEach(article => { %>
        <article class="tile">
          <a href="/journalism/<%= article.slug %>" class="tile-link">
            <div class="tile-thumb">
              <%- include('../partials/media-cover', { url: article.heroImageUrl || article.coverUrl, size: 'thumb', className: 'media-cover', variant: 'journal' }) %>
            </div>
            <div class="tile-body">
              <div class="tile-meta"><time><%= formatDate(article.datePublished) %></time></div>
              <h3 class="tile-title"><%= article.title %></h3>
            </div>
          </a>
        </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <section class="dash-panel">
      <div class="dash-panel-header">
        <h2 class="dash-panel-title">Browse</h2>
      </div>
      <div class="tile-grid">
        <article class="tile">
          <a href="/popsci" class="tile-link">
            <div class="tile-thumb" style="background: #EFF6FF; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">🔬</div>
            <div class="tile-body">
              <h3 class="tile-title">PopSci AI</h3>
              <p class="tile-excerpt">Science reels & explainers</p>
            </div>
          </a>
        </article>
        <article class="tile">
          <a href="/notes" class="tile-link">
            <div class="tile-thumb" style="background: #F5F3FF; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">📓</div>
            <div class="tile-body">
              <h3 class="tile-title">Notebooks</h3>
              <p class="tile-excerpt">Course notes and study journals</p>
            </div>
          </a>
        </article>
        <article class="tile">
          <a href="/writing-ideas" class="tile-link">
            <div class="tile-thumb" style="background: #FFFBEB; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">💡</div>
            <div class="tile-body">
              <h3 class="tile-title">Ideas</h3>
              <p class="tile-excerpt">Essay seeds and research clusters</p>
            </div>
          </a>
        </article>
        <article class="tile">
          <a href="/about" class="tile-link">
            <div class="tile-thumb" style="background: #F0FDF4; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">👤</div>
            <div class="tile-body">
              <h3 class="tile-title">About</h3>
              <p class="tile-excerpt">Background, links, and contact</p>
            </div>
          </a>
        </article>
      </div>
    </section>
  </div>

  <% if (courses && courses.length || articles && articles.length) { %>
  <section class="dash-panel" style="margin-top: var(--gap-lg);">
    <div class="dash-panel-header">
      <h2 class="dash-panel-title">From the Shelf</h2>
      <a href="/shelf" class="dash-panel-link">Full shelf &rarr;</a>
    </div>
    <div class="shelf-compact">
      <% if (courses && courses.length) { %>
      <div class="shelf-col">
        <h4><a href="/courses">Courses</a></h4>
        <ul class="shelf-list">
          <% courses.slice(0, 4).forEach(course => { %>
          <li><a href="<%= course.url || '/courses' %>" <%= course.url ? 'target="_blank" rel="noopener"' : '' %>><strong><%= course.title %></strong><span><%= course.platform || (course.status ? course.status.replace(/-/g, ' ') : 'queued') %></span></a></li>
          <% }) %>
        </ul>
      </div>
      <% } %>
      <% if (articles && articles.length) { %>
      <div class="shelf-col">
        <h4><a href="/articles-read">Reading Log</a></h4>
        <ul class="shelf-list">
          <% articles.slice(0, 4).forEach(article => { %>
          <li><a href="<%= article.url || '/articles-read' %>" <%= article.url ? 'target="_blank" rel="noopener"' : '' %>><strong><%= article.title %></strong><span><%= article.source || 'article' %></span></a></li>
          <% }) %>
        </ul>
      </div>
      <% } %>
      <div class="shelf-col">
        <h4>More</h4>
        <ul class="shelf-list">
          <li><a href="/research-papers"><strong>Research Papers</strong><span>Academic references</span></a></li>
          <li><a href="/stories"><strong>Fiction</strong><span>AUIS Literary Journal</span></a></li>
          <li><a href="/travel"><strong>Travel</strong><span>Itineraries & plans</span></a></li>
          <li><a href="/reflections"><strong>Reflections</strong><span>Personal notes</span></a></li>
        </ul>
      </div>
    </div>
  </section>
  <% } %>

</main>

<%- include('../partials/footer') %>
