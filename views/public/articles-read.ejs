<%- include('../partials/head', { title, isAdmin: false }) %>
<%- include('../partials/nav-public') %>

<main class="public-main">
  <section class="page-hero page-hero--compact">
    <p class="hero-eyebrow">Reading Log</p>
    <h1>Articles</h1>
    <p>Essays, journalism, and long reads — split between my queue and what I've finished. From my <a href="https://www.notion.so/Articles-Read-6539067f0ff84d5b9c64c742fdc8dc13" target="_blank" rel="noopener">Notion reading list</a>.</p>
    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
    <a href="/admin/content/articles_read" class="admin-inline-link">Edit in Admin</a>
    <% } %>
  </section>

  <div class="reading-status-tabs">
    <a href="/articles-read<%= currentTag ? '?tag=' + encodeURIComponent(currentTag) : '' %>" class="filter-tab<%= !currentView ? ' active' : '' %>">All</a>
    <a href="/articles-read?view=to-read<%= currentTag ? '&tag=' + encodeURIComponent(currentTag) : '' %>" class="filter-tab<%= currentView === 'to-read' ? ' active' : '' %>">To Read <span class="tab-count"><%= toRead.length %></span></a>
    <a href="/articles-read?view=have-read<%= currentTag ? '&tag=' + encodeURIComponent(currentTag) : '' %>" class="filter-tab<%= currentView === 'have-read' ? ' active' : '' %>">Have Read <span class="tab-count"><%= haveRead.length %></span></a>
  </div>

  <% if (allTags && allTags.length) { %>
  <div class="filter-tabs filter-tabs--secondary">
    <a href="/articles-read<%= currentView ? '?view=' + currentView : '' %>" class="filter-tab filter-tab--small<%= !currentTag ? ' active' : '' %>">All tags</a>
    <% allTags.slice(0, 12).forEach(tag => { %>
    <a href="/articles-read?tag=<%= encodeURIComponent(tag) %><%= currentView ? '&view=' + currentView : '' %>" class="filter-tab filter-tab--small<%= currentTag === tag ? ' active' : '' %>"><%= tag %></a>
    <% }) %>
  </div>
  <% } %>

  <% if (!currentView) { %>
  <% if (toRead.length) { %>
  <section class="reading-shelf-section">
    <h2 class="reading-shelf-heading">To Read</h2>
    <div class="articles-grid articles-grid--detailed">
      <% toRead.forEach(article => { %>
      <%- include('../partials/article-card', { article }) %>
      <% }) %>
    </div>
  </section>
  <% } %>
  <% if (haveRead.length) { %>
  <section class="reading-shelf-section">
    <h2 class="reading-shelf-heading">Have Read</h2>
    <div class="articles-grid articles-grid--detailed">
      <% haveRead.forEach(article => { %>
      <%- include('../partials/article-card', { article }) %>
      <% }) %>
    </div>
  </section>
  <% } %>
  <% } else { %>
  <div class="articles-grid articles-grid--detailed">
    <% articles.forEach(article => { %>
    <%- include('../partials/article-card', { article }) %>
    <% }) %>
  </div>
  <% if (!articles.length) { %>
  <p class="reading-shelf-empty">Nothing here yet.</p>
  <% } %>
  <% } %>
</main>

<%- include('../partials/footer') %>
