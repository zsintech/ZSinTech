<header class="site-header" id="site-header">
  <%- include('admin-toolbar') %>
  <nav class="nav-public">
    <a href="/" class="nav-logo">Z<span class="logo-accent">S</span>inTech</a>
    <div class="nav-links">
      <a href="/projects" class="<%= currentPath === '/projects' ? 'active' : '' %>">Projects</a>
      <a href="/activities" class="<%= currentPath.startsWith('/activities') ? 'active' : '' %>">Activity</a>
      <a href="/journalism" class="<%= currentPath.startsWith('/journalism') ? 'active' : '' %>">Journalism</a>
      <a href="/writings" class="<%= currentPath.startsWith('/writings') && currentPath !== '/projects' ? 'active' : '' %>">Essays</a>
      <a href="/popsci" class="<%= currentPath.startsWith('/popsci') ? 'active' : '' %>">PopSci</a>
      <span class="nav-divider" aria-hidden="true"></span>
      <a href="/notes" class="<%= currentPath.startsWith('/notes') ? 'active' : '' %>">Notes</a>
      <a href="/shelf" class="<%= currentPath === '/shelf' || currentPath.startsWith('/books/') || currentPath === '/courses' ? 'active' : '' %>">Shelf</a>
      <a href="/writing-ideas" class="<%= currentPath.startsWith('/writing-ideas') ? 'active' : '' %>">Ideas</a>
    </div>
    <button class="theme-toggle" aria-label="Toggle dark mode">
      <span class="icon-moon">&#9790;</span>
      <span class="icon-sun">&#9788;</span>
    </button>
    <button class="nav-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>
