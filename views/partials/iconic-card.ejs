<article class="iconic-card iconic-card--detailed card-lift">
  <%- include('media-cover', { url: item.coverUrl, size: 'card', className: 'iconic-cover media-cover', variant: 'book' }) %>
  <div class="iconic-card-body">
    <span class="iconic-type"><%= item.type %></span>
    <h2><%= item.title %></h2>
    <% if (item.author) { %>
    <p class="iconic-author">by <%= item.author %></p>
    <% } %>
    <p class="iconic-excerpt"><%= item.excerpt %></p>
    <% if (item.notes) { %>
    <div class="iconic-notes"><%= item.notes %></div>
    <% } %>
    <% if (item.tags && item.tags.length) { %>
    <div class="tags">
      <% item.tags.forEach(tag => { %>
      <span class="tag"><%= tag %></span>
      <% }) %>
    </div>
    <% } %>
    <% if (item.url) { %>
    <a href="<%= item.url %>" target="_blank" rel="noopener" class="read-more">View on Goodreads &rarr;</a>
    <% } %>
  </div>
</article>
