<%- include('../partials/head', { title, isAdmin: true }) %>
<div class="admin-layout">
  <%- include('../partials/nav-admin') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Books</h1>
      <a href="/admin/books/new" class="btn btn-primary">+ Add Book</a>
    </div>

    <div class="filters">
      <select onchange="location.href='/admin/books?status='+this.value">
        <option value="">All Status</option>
        <% statusValues.forEach(s => { %>
        <option value="<%= s %>" <%= currentStatus === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
      <select onchange="location.href='/admin/books?category='+this.value">
        <option value="">All Categories</option>
        <% categories.forEach(c => { %>
        <option value="<%= c %>" <%= currentCategory === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
    </div>

    <div class="kanban-board">
      <% const groups = { 'want-to-read': [], 'reading': [], 'finished': [] }; %>
      <% items.forEach(item => { if (groups[item.status]) groups[item.status].push(item); }) %>

      <% Object.entries(groups).forEach(([status, groupItems]) => { %>
      <div class="kanban-column">
        <h3 class="kanban-title"><%= status.replace(/-/g, ' ') %> (<%= groupItems.length %>)</h3>
        <% groupItems.forEach(item => { %>
        <div class="item-card">
          <div class="item-card-header">
            <h4><%= item.title %></h4>
            <button class="toggle-public-btn <%= item.isPublic ? 'is-public' : '' %>"
                    data-collection="books" data-id="<%= item.id %>">
              <%= item.isPublic ? '🌐 Public' : '🔒 Private' %>
            </button>
          </div>
          <p class="muted"><%= item.author || '' %></p>
          <% if (item.category) { %><span class="tag"><%= item.category %></span><% } %>
          <% if (item.rating) { %><span class="rating">★ <%= item.rating %>/5</span><% } %>
          <div class="item-card-actions">
            <a href="/admin/books/<%= item.id %>/edit" class="btn btn-small">Edit</a>
            <form action="/admin/books/<%= item.id %>/delete" method="POST" style="display:inline"
                  onsubmit="return confirm('Delete this book?')">
              <button type="submit" class="btn btn-small btn-danger">Delete</button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
      <% }) %>
    </div>
  </main>
</div>
<script src="/js/toggle-public.js"></script>
<%- include('../partials/footer') %>
