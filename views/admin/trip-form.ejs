<%- include('../partials/head', { title, isAdmin: true }) %>
<div class="admin-layout">
  <%- include('../partials/nav-admin') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1><%= item ? 'Edit' : 'Add' %> Trip</h1>
      <a href="/admin/trips" class="btn btn-outline">&larr; Back</a>
    </div>

    <form action="<%= item ? '/admin/trips/' + item.id : '/admin/trips' %>" method="POST" class="content-form">
      <div class="form-group">
        <label for="title">Title *</label>
        <input type="text" id="title" name="title" value="<%= item ? item.title : '' %>" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="destination">Destination</label>
          <input type="text" id="destination" name="destination" value="<%= item ? item.destination || '' : '' %>" placeholder="e.g. Athens, Greece">
        </div>
        <div class="form-group">
          <label for="slug">Slug</label>
          <input type="text" id="slug" name="slug" value="<%= item ? item.slug || '' : '' %>" placeholder="auto-generated if blank">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="status">Status</label>
          <select id="status" name="status">
            <% statusValues.forEach(s => { %>
            <option value="<%= s %>" <%= item && item.status === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="budget">Budget note</label>
          <input type="text" id="budget" name="budget" value="<%= item ? item.budget || '' : '' %>" placeholder="e.g. 8 Past Papers">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="dateStart">Start date</label>
          <input type="text" id="dateStart" name="dateStart" value="<%= item ? item.dateStart || '' : '' %>" placeholder="Optional">
        </div>
        <div class="form-group">
          <label for="dateEnd">End date</label>
          <input type="text" id="dateEnd" name="dateEnd" value="<%= item ? item.dateEnd || '' : '' %>" placeholder="Optional">
        </div>
      </div>

      <div class="form-group">
        <label for="concept">Concept</label>
        <input type="text" id="concept" name="concept" value="<%= item ? item.concept || '' : '' %>">
      </div>

      <div class="form-group">
        <label for="notes">Notes</label>
        <textarea id="notes" name="notes" rows="4"><%= item ? item.notes || '' : '' %></textarea>
      </div>

      <div class="form-group">
        <label for="heroImageUrl">Hero image URL</label>
        <input type="url" id="heroImageUrl" name="heroImageUrl" value="<%= item ? item.heroImageUrl || '' : '' %>" placeholder="Pexels or other image URL">
      </div>

      <div class="form-group">
        <label for="linksJson">Links (JSON array)</label>
        <textarea id="linksJson" name="linksJson" rows="5" placeholder='[{"title":"Tickets","url":"https://..."}]'><%= item && item.links ? JSON.stringify(item.links, null, 2) : '[]' %></textarea>
      </div>

      <div class="form-group">
        <label for="checklistJson">Checklist (JSON array)</label>
        <textarea id="checklistJson" name="checklistJson" rows="6" placeholder='[{"text":"Visit museum","done":false}]'><%= item && item.checklist ? JSON.stringify(item.checklist, null, 2) : '[]' %></textarea>
      </div>

      <div class="form-group">
        <label for="tags">Tags (comma-separated)</label>
        <input type="text" id="tags" name="tags" value="<%= item && item.tags ? item.tags.join(', ') : '' %>">
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="hidden" name="isPublic" value="false">
          <input type="checkbox" name="isPublic" value="true" <%= item && item.isPublic ? 'checked' : '' %>>
          Make public on /travel
        </label>
        <p class="form-hint">Private trips are only visible in admin — never shown on the public site.</p>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Trip</button>
      </div>
    </form>
  </main>
</div>
<%- include('../partials/footer') %>
