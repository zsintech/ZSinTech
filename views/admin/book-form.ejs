<%- include('../partials/head', { title, isAdmin: true }) %>
<div class="admin-layout">
  <%- include('../partials/nav-admin') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1><%= item ? 'Edit' : 'Add' %> Book</h1>
      <a href="/admin/books<%= item && item.shelfType ? '?shelfType=' + item.shelfType : (typeof defaultShelfType !== 'undefined' && defaultShelfType ? '?shelfType=' + defaultShelfType : '') %>" class="btn btn-outline">&larr; Back</a>
    </div>

    <form action="<%= item ? '/admin/books/' + item.id : '/admin/books' %>" method="POST" class="content-form">
      <div class="form-group">
        <label for="title">Title *</label>
        <input type="text" id="title" name="title" value="<%= item ? item.title : '' %>" required>
      </div>

      <div class="form-group">
        <label for="author">Author</label>
        <input type="text" id="author" name="author" value="<%= item ? item.author || '' : '' %>">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="shelfType">Shelf *</label>
          <select id="shelfType" name="shelfType" required>
            <% shelfTypeValues.forEach(st => { %>
            <option value="<%= st %>"
              <%= (item && item.shelfType === st) || (!item && typeof defaultShelfType !== 'undefined' && defaultShelfType === st) ? 'selected' : '' %>>
              <%= st.charAt(0).toUpperCase() + st.slice(1) %>
            </option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="to-read" <%= item && (item.status === 'to-read' || item.status === 'want-to-read' || item.status === 'reading') ? 'selected' : (!item ? 'selected' : '') %>>To Read</option>
            <option value="have-read" <%= item && (item.status === 'have-read' || item.status === 'finished' || item.status === 'read') ? 'selected' : '' %>>Have Read</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="category">Category</label>
        <input type="text" id="category" name="category" value="<%= item ? item.category || '' : '' %>"
               list="categories-list" placeholder="e.g. Medicine, Fiction">
        <datalist id="categories-list">
          <% if (typeof categories !== 'undefined') { categories.forEach(c => { %>
          <option value="<%= c %>">
          <% }) } %>
        </datalist>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="rating">Rating (1-5)</label>
          <input type="number" id="rating" name="rating" min="1" max="5" value="<%= item && item.rating ? item.rating : '' %>">
        </div>
        <div class="form-group">
          <label for="coverUrl">Cover URL</label>
          <input type="url" id="coverUrl" name="coverUrl" value="<%= item ? item.coverUrl || '' : '' %>" placeholder="Leave blank for auto-fetch">
        </div>
      </div>

      <div class="form-group">
        <label for="tags">Tags (comma-separated)</label>
        <input type="text" id="tags" name="tags" value="<%= item && item.tags ? item.tags.join(', ') : '' %>">
      </div>

      <div class="form-group">
        <label for="notes">Notes</label>
        <textarea id="notes" name="notes" rows="5"><%= item ? item.notes || '' : '' %></textarea>
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="hidden" name="isPublic" value="false">
          <input type="checkbox" name="isPublic" value="true" <%= !item || item.isPublic !== false ? 'checked' : '' %>>
          Make public
        </label>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Book</button>
      </div>
    </form>
  </main>
</div>
<%- include('../partials/footer') %>
