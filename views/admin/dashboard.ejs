<%- include('../partials/head', { title, isAdmin: true }) %>
<div class="admin-layout">
  <%- include('../partials/nav-admin') %>
  <main class="admin-main">
    <div class="admin-header">
      <div class="admin-header-text">
        <h1>Dashboard</h1>
        <p class="page-desc">Welcome back — your workspace for everything ZsinTech.</p>
      </div>
      <div class="admin-header-actions">
        <a href="/admin/notebooks/new" class="btn btn-primary"><span class="btn-icon">+</span> New Note</a>
        <a href="/admin/content" class="btn btn-outline">Content Hub</a>
      </div>
    </div>

    <div class="stats-grid">
      <a href="/admin/notebooks" class="stat-card stat-card--link">
        <span class="stat-icon">📝</span>
        <div class="stat-info">
          <span class="stat-number"><%= stats.notebooks || 0 %></span>
          <span class="stat-label">Notebooks</span>
        </div>
      </a>
      <a href="/admin/books" class="stat-card stat-card--link">
        <span class="stat-icon">📚</span>
        <div class="stat-info">
          <span class="stat-number"><%= stats.totalBooks %></span>
          <span class="stat-label">Books</span>
        </div>
      </a>
      <a href="/admin/books?status=reading" class="stat-card stat-card--link">
        <span class="stat-icon">📖</span>
        <div class="stat-info">
          <span class="stat-number"><%= stats.reading %></span>
          <span class="stat-label">Reading</span>
        </div>
      </a>
      <a href="/admin/content/articles_read?status=want-to-read" class="stat-card stat-card--link">
        <span class="stat-icon">📰</span>
        <div class="stat-info">
          <span class="stat-number"><%= stats.articlesToRead %></span>
          <span class="stat-label">To Read</span>
        </div>
      </a>
      <a href="/admin/courses?status=want-to-take" class="stat-card stat-card--link">
        <span class="stat-icon">🎓</span>
        <div class="stat-info">
          <span class="stat-number"><%= stats.coursesToTake || 0 %></span>
          <span class="stat-label">Courses</span>
        </div>
      </a>
    </div>

    <div class="dashboard-grid">
      <section class="dashboard-section dashboard-section--activity">
        <div class="section-header">
          <h2>Recent Activity</h2>
          <a href="/admin/content" class="section-link">View all</a>
        </div>
        <% if (recentItems.length === 0) { %>
          <div class="empty-state">
            <p>No recent items — start by creating a notebook or adding content.</p>
          </div>
        <% } else { %>
        <div class="recent-list">
          <% recentItems.forEach(item => { %>
          <div class="recent-item">
            <span class="recent-collection"><%= item.collection %></span>
            <span class="recent-title"><%= item.title || item.body?.substring(0, 40) || 'Untitled' %></span>
            <span class="recent-date"><%= formatDate(item.dateAdded) %></span>
          </div>
          <% }) %>
        </div>
        <% } %>
      </section>

      <section class="dashboard-section dashboard-section--quickadd">
        <div class="section-header">
          <h2>Quick Add</h2>
        </div>
        <form action="/admin/quick-add" method="POST" class="quick-add-form">
          <div class="form-group">
            <select name="collection" required>
              <option value="">Choose type...</option>
              <option value="books">Book</option>
              <option value="courses">Course</option>
              <option value="articles_saved">Article</option>
              <option value="writings">Writing</option>
              <option value="movies">Movie</option>
              <option value="reflections">Reflection</option>
            </select>
          </div>
          <div class="form-group">
            <input type="text" name="title" placeholder="Title" required>
          </div>
          <div class="form-group">
            <textarea name="body" placeholder="Notes or body (optional)" rows="3"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-block">Add Item</button>
        </form>
      </section>
    </div>

    <div class="dashboard-shortcuts">
      <h2 class="shortcuts-title">Quick Access</h2>
      <div class="shortcuts-grid">
        <a href="/admin/notebooks" class="shortcut-card shortcut-card--featured">
          <span class="shortcut-icon">📝</span>
          <div class="shortcut-info">
            <strong>Notebooks</strong>
            <span>Study notes & course journals</span>
          </div>
        </a>
        <a href="/admin/writings" class="shortcut-card">
          <span class="shortcut-icon">✍️</span>
          <div class="shortcut-info">
            <strong>Writings</strong>
            <span>Essays & projects</span>
          </div>
        </a>
        <a href="/admin/courses" class="shortcut-card">
          <span class="shortcut-icon">🎓</span>
          <div class="shortcut-info">
            <strong>Courses</strong>
            <span>Learning shelf</span>
          </div>
        </a>
        <a href="/admin/trips" class="shortcut-card">
          <span class="shortcut-icon">✈️</span>
          <div class="shortcut-info">
            <strong>Travel</strong>
            <span>Trips & plans</span>
          </div>
        </a>
        <a href="/admin/content/journalism" class="shortcut-card">
          <span class="shortcut-icon">🗞️</span>
          <div class="shortcut-info">
            <strong>Journalism</strong>
            <span>Published articles</span>
          </div>
        </a>
        <a href="/admin/content/popsci_reels" class="shortcut-card">
          <span class="shortcut-icon">🧪</span>
          <div class="shortcut-info">
            <strong>PopSci</strong>
            <span>Science reels</span>
          </div>
        </a>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
