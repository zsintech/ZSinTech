<%- include('../partials/head', { title, isAdmin: true }) %>
<div class="admin-layout">
  <%- include('../partials/nav-admin') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Writings</h1>
      <a href="/admin/writings/new" class="btn btn-primary">+ Add Writing</a>
    </div>

    <div class="filters">
      <select onchange="location.href='/admin/writings?category='+this.value">
        <option value="">All Types</option>
        <option value="essay">Essays</option>
        <option value="project">Projects</option>
        <option value="research">Research</option>
        <option value="story">Stories</option>
        <option value="note">Notes</option>
      </select>
    </div>

    <div class="items-list">
      <% if (items.length === 0) { %>
        <p class="empty-state">No writings yet.</p>
      <% } %>
      <% items.forEach(item => { %>
      <div class="item-card item-card-horizontal">
        <div class="item-card-header">
          <div>
            <span class="item-type-badge"><%= item.type || 'note' %></span>
            <h4><%= item.title %></h4>
            <p class="muted"><%= item.excerpt || '' %></p>
            <p class="muted small"><%= item.slug ? '/writings/' + item.slug : '' %></p>
          </div>
          <button class="toggle-public-btn <%= item.isPublic ? 'is-public' : '' %>"
                  data-collection="writings" data-id="<%= item.id %>">
            <%= item.isPublic ? '🌐 Public' : '🔒 Private' %>
          </button>
        </div>
        <div class="item-card-actions">
          <span class="muted"><%= formatDate(item.dateWritten) %></span>
          <a href="/admin/writings/<%= item.id %>/edit" class="btn btn-small">Edit</a>
          <form action="/admin/writings/<%= item.id %>/delete" method="POST" style="display:inline"
                onsubmit="return confirm('Delete this writing?')">
            <button type="submit" class="btn btn-small btn-danger">Delete</button>
          </form>
        </div>
      </div>
      <% }) %>
    </div>
  </main>
</div>
<script src="/js/toggle-public.js"></script>
<%- include('../partials/footer') %>
