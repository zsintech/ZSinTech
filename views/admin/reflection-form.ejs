<%- include('../partials/head', { title, isAdmin: true }) %>
<div class="admin-layout">
  <%- include('../partials/nav-admin') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1><%= item ? 'Edit' : 'Add' %> Reflection</h1>
      <a href="/admin/reflections" class="btn btn-outline">&larr; Back</a>
    </div>

    <form action="<%= item ? '/admin/reflections/' + item.id : '/admin/reflections' %>" method="POST" class="content-form">
      <div class="form-group">
        <label for="title">Title (optional)</label>
        <input type="text" id="title" name="title" value="<%= item ? item.title || '' : '' %>">
      </div>

      <div class="form-group">
        <label for="body">Reflection *</label>
        <textarea id="body" name="body" rows="10" required><%= item ? item.body || '' : '' %></textarea>
      </div>

      <div class="form-group">
        <label for="mood">Mood (optional)</label>
        <input type="text" id="mood" name="mood" value="<%= item ? item.mood || '' : '' %>" placeholder="e.g. sharp, uncertain, calm, restless">
      </div>

      <div class="form-group">
        <label for="tags">Tags (comma-separated)</label>
        <input type="text" id="tags" name="tags" value="<%= item && item.tags ? item.tags.join(', ') : '' %>">
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="hidden" name="isPublic" value="false">
          <input type="checkbox" name="isPublic" value="true" <%= item && item.isPublic ? 'checked' : '' %>>
          Make public
        </label>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Reflection</button>
      </div>

      <% if (typeof connections !== 'undefined' && connections && connections.length > 0) { %>
      <section class="connections-section">
        <h3>Connections</h3>
        <div class="connections-list">
          <% connections.forEach(c => { %>
          <div class="connection-item">
            <span><%= c.fromTitle %></span>
            <span class="connection-label"><%= c.label %></span>
            <span><%= c.toTitle %></span>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>
    </form>
  </main>
</div>
<%- include('../partials/footer') %>
