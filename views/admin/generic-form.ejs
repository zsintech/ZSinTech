<%- include('../partials/head', { title, isAdmin: true }) %>
<div class="admin-layout">
  <%- include('../partials/nav-admin') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1><%= item ? 'Edit' : 'Add' %> <%= section.singular %></h1>
      <a href="/admin/content/<%= section.collection %>" class="btn btn-outline">&larr; Back</a>
    </div>

    <form action="<%= item ? '/admin/content/' + section.collection + '/' + item.id : '/admin/content/' + section.collection %>" method="POST" class="content-form">
      <% section.fields.forEach(field => { %>
      <div class="form-group">
        <label for="<%= field.name %>"><%= field.label %><%= field.required ? ' *' : '' %></label>

        <% if (field.type === 'textarea') { %>
        <textarea id="<%= field.name %>" name="<%= field.name %>" rows="<%= field.rows || 4 %>" <%= field.required ? 'required' : '' %>><%= item ? (item[field.name] || '') : '' %></textarea>

        <% } else if (field.type === 'select') { %>
        <select id="<%= field.name %>" name="<%= field.name %>">
          <% const opts = field.optionsKey === 'statusValues' ? section.statusValues : (field.options || []); %>
          <% opts.forEach(opt => { %>
          <option value="<%= opt %>" <%= item && item[field.name] === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>

        <% } else if (field.type === 'tags') { %>
        <input type="text" id="<%= field.name %>" name="<%= field.name %>" value="<%= item && item.tags ? item.tags.join(', ') : '' %>" placeholder="comma-separated">

        <% } else if (field.type === 'checkbox') { %>
        <label class="checkbox-label">
          <input type="hidden" name="<%= field.name %>" value="false">
          <input type="checkbox" name="<%= field.name %>" value="true" <%= item && item.isPublic ? 'checked' : (!item ? 'checked' : '') %>>
          Visible on the public site
        </label>

        <% } else if (field.type === 'url') { %>
        <div class="url-field-group">
          <input type="url" id="<%= field.name %>" name="<%= field.name %>"
                 value="<%= item ? (item[field.name] || '') : '' %>"
                 placeholder="<%= field.placeholder || 'https://...' %>">
          <% if (item && item[field.name] && (field.name.includes('image') || field.name.includes('Image') || field.name.includes('cover') || field.name.includes('Cover'))) { %>
          <div class="url-field-preview" style="margin-top: 0.5rem;">
            <img src="<%= item[field.name] %>" alt="preview" style="max-width: 200px; max-height: 120px; border-radius: 8px; border: 1px solid var(--border, #e5e7eb);" onerror="this.style.display='none'">
          </div>
          <% } %>
        </div>

        <% } else { %>
        <input type="<%= field.type === 'number' ? 'number' : 'text' %>"
               id="<%= field.name %>" name="<%= field.name %>"
               value="<%= item ? (item[field.name] || '') : '' %>"
               <%= field.placeholder ? 'placeholder="' + field.placeholder + '"' : '' %>
               <%= field.required ? 'required' : '' %>>
        <% } %>
      </div>
      <% }) %>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save</button>
        <% if (item && section.publicPath) { %>
        <a href="<%= section.publicPath %>/<%= item.slug || item.id %>" class="btn btn-outline" target="_blank">Preview</a>
        <% } %>
      </div>
    </form>
  </main>
</div>
<%- include('../partials/footer') %>
